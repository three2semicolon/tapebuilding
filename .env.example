# spotify - https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# profile
SPOTIFY_USER_ID=

# paths
ARCHIVE_PATH=        # full library archive, e.g. /Volumes/music/archive
TAPEDECK_PATH=       # tapedeck e.g. Y:/music/tapedeck
PLAYLISTS_PATH=      # .m3u playlist files, e.g. Y:/music/playlists

# download
DOWNLOAD_FORMAT=mp3
DOWNLOAD_QUALITY=320k

# ffmpeg
FFMPEG_PATH=

# soundbyte - album management
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=   # Path to service account JSON
